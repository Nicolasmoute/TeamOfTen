# TeamOfTen — example environment file.
#
# Copy to `.env` (or paste the relevant lines into your platform's env
# settings UI) and edit as needed. Every var is optional — unset vars
# fall back to sensible defaults. The harness boots fine with NO env
# set, though you'll want to at least set HARNESS_TOKEN before
# exposing it to the internet.

# ---------------------------------------------------------------------
# Auth
# ---------------------------------------------------------------------

# Bearer token required on every /api/* request (except /api/health)
# and on the WebSocket as ?token=. If unset, the API is open — fine
# for localhost, not OK on a public URL.
HARNESS_TOKEN=

# ---------------------------------------------------------------------
# Claude Code authentication persistence
# ---------------------------------------------------------------------

# Where the Claude CLI stores OAuth tokens (.credentials.json) and
# session JSONL files. Point at a path on your persistent volume so
# tokens survive redeploys. Strongly recommended.
CLAUDE_CONFIG_DIR=/data/claude

# ---------------------------------------------------------------------
# OpenAI Codex runtime authentication persistence
# ---------------------------------------------------------------------

# Enable the per-slot Codex runtime selector. When unset/false, the UI
# can show Codex auth status but the API rejects runtime=codex.
HARNESS_CODEX_ENABLED=true

# Where the Codex CLI stores ChatGPT OAuth credentials (auth.json).
# Point at a persistent volume. Then run inside the deployed container:
#   export CODEX_HOME=/data/codex
#   codex login --device-auth
# The UI should then show "ChatGPT session: present". The API-key box in
# Settings is only a token-priced fallback and is not needed when the
# ChatGPT session is present.
CODEX_HOME=/data/codex

# ---------------------------------------------------------------------
# Project repository (per-Player git worktrees)
# ---------------------------------------------------------------------

# GitHub (or other) repo each Player will work on. Embed a PAT in the
# URL for private repos. Without this, Players have no project to
# touch — they still exist but can't code.
# Example: https://${GITHUB_TOKEN}@github.com/you/your-repo.git
HARNESS_PROJECT_REPO=

# Override the default branch detection. Leave blank to use the
# repo's HEAD.
HARNESS_PROJECT_BRANCH=

# ---------------------------------------------------------------------
# WebDAV mirror (optional — durable backup beyond the local volume)
# ---------------------------------------------------------------------

# Works with any WebDAV-compatible cloud drive: Infomaniak kDrive,
# Nextcloud, ownCloud, Fastmail Files, etc. If you want something
# more exotic (S3, OAuth flows), fork and swap server/webdav.py —
# the interface is ~10 methods.
#
# All three must be set or the mirror stays disabled (the app still
# works, writes just live on the local volume only).
HARNESS_WEBDAV_URL=
HARNESS_WEBDAV_USER=
HARNESS_WEBDAV_PASSWORD=

# Flush cadences (seconds). Default 300 (5 min) for both.
HARNESS_WEBDAV_FLUSH_INTERVAL=300
HARNESS_WEBDAV_SNAPSHOT_INTERVAL=300
# How many DB snapshots to keep on the mirror. 144 = ~12 h at 5 min.
HARNESS_WEBDAV_SNAPSHOT_RETENTION=144

# ---------------------------------------------------------------------
# Cost caps (USD / day, per Max-plan OAuth billing estimate)
# ---------------------------------------------------------------------

# Per-Player daily limit. Agent won't spawn if today's spend ≥ this.
HARNESS_AGENT_DAILY_CAP=5.0
# Whole-team daily limit. Overrides per-Player when hit.
HARNESS_TEAM_DAILY_CAP=20.0

# ---------------------------------------------------------------------
# Data paths (persistent — point at your /data volume)
# ---------------------------------------------------------------------

HARNESS_DB_PATH=/data/harness.db
HARNESS_CONTEXT_DIR=/data/context
HARNESS_KNOWLEDGE_DIR=/data/knowledge
HARNESS_DECISIONS_DIR=/data/decisions
HARNESS_OUTPUTS_DIR=/data/outputs
HARNESS_UPLOADS_DIR=/data/uploads
HARNESS_ATTACHMENTS_DIR=/data/attachments
HARNESS_HANDOFFS_DIR=/data/handoffs
HARNESS_WORKSPACES_DIR=/workspaces

# ---------------------------------------------------------------------
# Retention (days, 0 disables the sweep)
# ---------------------------------------------------------------------

HARNESS_EVENTS_RETENTION_DAYS=30
HARNESS_ATTACHMENTS_RETENTION_DAYS=30
HARNESS_SESSION_RETENTION_DAYS=30
HARNESS_EVENTS_TRIM_INTERVAL=86400

# ---------------------------------------------------------------------
# Reliability / workflow
# ---------------------------------------------------------------------

# Coach autoloop: seconds between Coach "drain inbox" ticks. 0 = off.
HARNESS_COACH_TICK_INTERVAL=0

# Auto-wake debounce after a chat reply (prevents ping-pong).
HARNESS_AUTOWAKE_DEBOUNCE=10

# Post-error auto-retry: delay + max consecutive errors before escalating.
HARNESS_ERROR_RETRY_DELAY=45
HARNESS_ERROR_RETRY_MAX_CONSECUTIVE=3

# Debounce between "Player errored → DM Coach" notifications (seconds).
HARNESS_ERROR_DM_DEBOUNCE=300

# Stale-task watchdog: notify Coach if an in-progress task has no owner
# activity in N minutes. 0 = off.
HARNESS_STALE_TASK_MINUTES=15
HARNESS_STALE_TASK_NOTIFY_INTERVAL_MINUTES=30
HARNESS_STALE_TASK_CHECK_INTERVAL_SECONDS=60

# ---------------------------------------------------------------------
# Compact / context management
# ---------------------------------------------------------------------

# Auto-compact when session context exceeds this fraction of the
# model's window. 0.7 = compact at 70% full.
HARNESS_AUTO_COMPACT_THRESHOLD=0.7

# Tokens of recent-exchange verbatim log preserved across a compact.
HARNESS_HANDOFF_TOKEN_BUDGET=20000

# Enable per-token streaming (experimental — some CLI versions crash).
HARNESS_STREAM_TOKENS=

# ---------------------------------------------------------------------
# Secrets store (encrypted MCP/tool credentials)
# ---------------------------------------------------------------------

# Fernet key for the secrets table (44-char urlsafe-base64). Generate
# via: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# Unset = secrets store disabled (MCP servers can still read ${VAR}
# placeholders from env directly).
HARNESS_SECRETS_KEY=

# ---------------------------------------------------------------------
# External MCP servers
# ---------------------------------------------------------------------

# Path to an MCP server config file. See mcp-servers.example.json.
HARNESS_MCP_CONFIG=/data/mcp-servers.json
